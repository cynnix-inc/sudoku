{
  "name": "soduku",
  "version": "1.0.1",
  "description": "A modern, interactive Sudoku game built with HTML, CSS, and JavaScript. Features a clean, responsive design with smooth animations and intuitive gameplay.",
  "main": "script.js",
  "scripts": {
    "test": "jest",
    "test:unit": "jest",
    "e2e": "playwright test",
    "e2e:install": "playwright install",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "lint:css": "stylelint \"**/*.css\"",
    "lint:css:fix": "stylelint \"**/*.css\" --fix",
    "check": "npm run lint && npm run lint:css && npm run test:unit && npm run e2e",
    "build:env": "node tools/generate-env.js",
    "build:version": "node tools/generate-version.js",
    "build:icons": "node tools/generate-icons.js",
    "serve": "npm run build:env && npm run build:version && npm run build:icons && http-server -p 5173 -c-1",
    "test:stubs": "node tools/gen-test-stubs.js",
    "e2e:ui": "playwright test --ui",
    "changelog": "node tools/update-changelog.js",
    "prepare": "husky install",
    "release": "semantic-release",
    "supabase:link": "npx --yes supabase link",
    "supabase:push": "npx --yes supabase db push",
    "version:bump:patch": "npm version patch -m \"chore: bump version to %s\" && npm run build:version",
    "version:bump:minor": "npm version minor -m \"chore: bump version to %s\" && npm run build:version",
    "version:bump:major": "npm version major -m \"chore: bump version to %s\" && npm run build:version"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ngroulx/soduku.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/ngroulx/soduku/issues"
  },
  "homepage": "https://github.com/ngroulx/soduku#readme",
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.0",
    "@semantic-release/exec": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^10.3.5",
    "@semantic-release/npm": "^12.0.1",
    "eslint": "^9.33.0",
    "eslint-config-prettier": "^9.1.2",
    "http-server": "^14.1.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.0.5",
    "prettier": "^3.6.2",
    "semantic-release": "^24.1.1",
    "stylelint": "^16.23.1",
    "stylelint-config-standard": "^39.0.0"
  }
}
