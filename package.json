    "deps:verify": "node scripts/verify-deps.mjs",
    "verify:deps": "node scripts/verify-deps.mjs",
    "ios": "expo run:ios",
    "build": "expo export --platform web --output dist",
    "ci": "npm run lint && npm run typecheck && npm test -- --ci && npm run build"
  },
