{
  "name": "ultimate-sudoku",
  "version": "1.8.0",
  "directories": {
    "doc": "docs"
  },
  "engines": {
    "node": ">=20 <21"
  },
  "scripts": {
    "dev": "npx expo start",
    "web": "npx expo start --web",
    "android": "npx expo run:android",
    "native:prebuild": "npx expo prebuild",
    "android:prebuild:ci": "npx expo prebuild -p android --non-interactive",
    "android:version:check": "node scripts/check-android-version.mjs",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "format": "prettier --check .",
    "typecheck": "tsc --pretty --noEmit",
    "test": "jest --passWithNoTests",
    "test:bdd": "jest --config __tests__/bdd/jest.config.bdd.js --passWithNoTests",
    "bundle:check": "node scripts/bundle-check.mjs",
    "deps:verify": "node scripts/verify-deps.mjs",
    "verify:deps": "node scripts/verify-deps.mjs",
    "ios": "npx expo run:ios",
    "build": "npx expo export --platform web --output-dir dist",
    "ci": "npm run lint && npm run typecheck && node scripts/check-android-version.mjs --fix && npm test -- --ci && npm run build",
    "prepare": "husky",
    "commit": "npx git-cz || true",
    "lint-staged": "lint-staged"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "volta": {
    "node": "20.19.4"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.47.10",
    "expo": "53.0.20",
    "expo-clipboard": "~6.0.3",
    "expo-haptics": "~14.1.4",
    "expo-linear-gradient": "~14.1.5",
    "expo-router": "~5.1.4",
    "expo-status-bar": "~2.2.3",
    "expo-system-ui": "~5.0.10",
    "nativewind": "^4.1.23",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-native": "0.79.5",
    "react-native-gesture-handler": "~2.24.0",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-web": "^0.20.0",
    "tailwindcss": "^3.4.14"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@changesets/cli": "^2.29.6",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@expo/cli": "^0.24.20",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.2.2",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.1.10",
    "@types/react-native": "^0.73.0",
    "@typescript-eslint/eslint-plugin": "^8.39.1",
    "@typescript-eslint/parser": "^8.39.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.33.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-cucumber": "^4.2.1",
    "jest-expo": "^53.0.9",
    "lighthouse-ci": "^1.13.1",
    "lint-staged": "^16.1.5",
    "prettier": "^3.6.2",
    "react-test-renderer": "^19.1.1",
    "typescript": "^5.9.2"
  }
}
