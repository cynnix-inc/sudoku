{
  "name": "ultimate-sudoku",
  "private": true,
  "version": "0.1.0",
  "description": "Ultimate Sudoku monorepo (Expo + NativeWind) - scaffolding only",
  "packageManager": "pnpm@9.12.0",
  "volta": {
    "node": "22.5.1",
    "pnpm": "9.12.0"
  },
  "scripts": {
    "dev": "pnpm --filter @ultimate-sudoku/app start",
    "web": "pnpm --filter @ultimate-sudoku/app run web",
    "ios": "pnpm --filter @ultimate-sudoku/app run ios",
    "android": "pnpm --filter @ultimate-sudoku/app run android",
    "docs:generate": "node scripts/generate-readme.mjs",
    "lint": "pnpm -r exec eslint .",
    "format": "pnpm -r exec prettier --write .",
    "test": "pnpm -r run test",
    "test:ci": "node scripts/check-tests.mjs && pnpm -r run test:ci",
    "e2e": "pnpm exec playwright test",
    "typecheck": "pnpm -r run typecheck",
    "prepare": "husky install",
    "release": "changeset version && git add -A && git commit -m 'chore: version packages' && git push && changeset tag && git push --follow-tags",
    "eas:update:preview": "pnpm --filter @ultimate-sudoku/app run eas:update:preview",
    "eas:update:prod": "pnpm --filter @ultimate-sudoku/app run eas:update:prod",
    "new:branch": "powershell -ExecutionPolicy Bypass -File ./scripts/new-branch.ps1"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "prettier": "@ultimate-sudoku/config/prettier",
  "eslintConfig": {
    "extends": [
      "@ultimate-sudoku/config/eslint"
    ]
  },
  "devDependencies": {
    "@babel/plugin-transform-flow-strip-types": "^7.27.1",
    "@babel/preset-env": "^7.28.3",
    "@babel/preset-react": "^7.27.1",
    "@babel/preset-typescript": "^7.27.1",
    "@commitlint/cli": "^19.2.2",
    "@commitlint/config-conventional": "^19.1.0",
    "@playwright/test": "^1.46.1",
    "@react-native/babel-preset": "^0.81.0",
    "babel-preset-expo": "^13.2.3",
    "eslint": "^9.9.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-simple-import-sort": "^12.1.0",
    "http-server": "^14.1.1",
    "husky": "^9.1.6",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.7",
    "prettier": "^3.3.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  }
}
