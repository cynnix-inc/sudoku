{
  "$schema": "https://raw.githubusercontent.com/semantic-release/semantic-release/master/schema/semantic-release.json",
  "branches": ["main"],
  "plugins": [
    ["@semantic-release/commit-analyzer", {
      "preset": "conventionalcommits"
    }],
    ["@semantic-release/changelog", {
      "changelogFile": "CHANGELOG.md"
    }],
    ["@semantic-release/npm", {
      "npmPublish": false
    }],
    ["@semantic-release/git", {
      "assets": ["CHANGELOG.md", "package.json", "src/version.js", "service-worker.js"],
      "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
    }],
    ["@semantic-release/exec", {
      "prepareCmd": "node tools/generate-version.js && node tools/update-sw-version.js ${nextRelease.version}"
    }],
    "@semantic-release/github"
  ]
}


