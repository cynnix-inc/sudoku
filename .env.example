# Ultimate Sudoku — Environment Example

# --------------------------------------
# App runtime (Expo web/native)
# These are read in `app/services/supabase.ts` and must be prefixed with EXPO_PUBLIC_
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# --------------------------------------
# Local database and seeding
# Used by docs/CLI commands like: psql "$SUPABASE_DB_URL" -f supabase/seed.sql
# Supabase local defaults (via `supabase start`) typically run on port 54322
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# --------------------------------------
# CI / automation (see docs and supabase/README.md)
# Provided to CI runners or GitHub Actions for migrations promotion flows
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF_STAGING=
SUPABASE_PROJECT_REF_PROD=

# Bundle baseline maintenance for CI budget checks
# Set to 1 to write ./dist/bundle-baseline.json when running bundle check
UPDATE_BUNDLE_BASELINE=0
